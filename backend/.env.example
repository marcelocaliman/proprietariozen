# ─────────────────────────────────────────────────────────────────────────────
# Asaas — conta raiz ProprietárioZen
# ─────────────────────────────────────────────────────────────────────────────

# Chave da conta raiz do ProprietárioZen no Asaas.
# Obter em: https://www.asaas.com/config/apiKey (ou sandbox equivalente)
ASAAS_API_KEY_ROOT=

# URL base da API Asaas. Trocar para produção ao fazer deploy.
#   Sandbox:   https://sandbox.asaas.com/api/v3
#   Produção:  https://api.asaas.com/v3
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

# ─────────────────────────────────────────────────────────────────────────────
# Criptografia das apiKeys das subcontas
# ─────────────────────────────────────────────────────────────────────────────

# Chave AES-256-GCM para criptografar as apiKeys armazenadas no banco.
# DEVE ser exatamente 64 caracteres hexadecimais (= 32 bytes).
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NUNCA commitar o valor real. Rotacionar exige re-encriptar todas as apiKeys.
ASAAS_ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Webhooks
# ─────────────────────────────────────────────────────────────────────────────

# URL pública do backend onde o Asaas vai enviar os eventos.
# Em desenvolvimento use ngrok: https://abc123.ngrok.io
# Em produção: https://api.proprietariezen.com.br
WEBHOOK_BASE_URL=

# Token de validação dos webhooks recebidos.
# Configurado ao registrar o webhook no Asaas e validado em cada requisição.
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ASAAS_WEBHOOK_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Banco de dados
# ─────────────────────────────────────────────────────────────────────────────

MONGODB_URI=mongodb://localhost:27017/proprietariezen

# ─────────────────────────────────────────────────────────────────────────────
# Autenticação JWT
# ─────────────────────────────────────────────────────────────────────────────

JWT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Firebase Admin (notificações push)
# ─────────────────────────────────────────────────────────────────────────────

# Caminho para o arquivo de credenciais do Firebase Admin SDK.
# Baixar em: Firebase Console → Configurações do Projeto → Contas de serviço
FIREBASE_CREDENTIAL_PATH=./firebase-credentials.json

# ─────────────────────────────────────────────────────────────────────────────
# E-mail SMTP (notificações de cobrança ao inquilino)
# ─────────────────────────────────────────────────────────────────────────────

# Se EMAIL_HOST não for definido, os e-mails são apenas logados no console (dev).
# Em produção, configurar um servidor SMTP (ex: SendGrid, Resend, Gmail, etc.).
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=ProprietárioZen <noreply@proprietariezen.com.br>

# ─────────────────────────────────────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────────────────────────────────────

PORT=3001
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Migração para White Label (quando aplicável)
# ─────────────────────────────────────────────────────────────────────────────
# Ao migrar para White Label, adicionar:
#   ASAAS_WHITELABEL_SUBDOMAIN=proprietariezen
# e descomentar o campo `loginEmailSmtp` no payload do POST /accounts.
# Ver ASAAS_INTEGRATION.md → seção "Migração para White Label".
# ─────────────────────────────────────────────────────────────────────────────
